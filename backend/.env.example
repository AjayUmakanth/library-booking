# Copy to .env and edit values.

PORT=3000
NODE_ENV=development
APP_TIMEZONE=Europe/Berlin

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Used for cancel links when the client does not send X-Frontend-Origin (e.g. non-browser). No trailing slash.
FRONTEND_URL=http://localhost:3001

# CORS: exact browser origin(s); comma-separated for several.
FRONTEND_ORIGIN=http://localhost:3001

# SQLITE_PATH=
