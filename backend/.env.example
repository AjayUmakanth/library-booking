PORT=3000
NODE_ENV=development
# IANA timezone for “today”, opening hours, and ongoing sessions (e.g. Europe/Berlin, Europe/Paris)
APP_TIMEZONE=Europe/Berlin
# Required in production — use a long random string
JWT_SECRET=change-this-to-a-long-random-string
# Access token lifetime (jsonwebtoken format, e.g. 7d, 24h, 3600)
JWT_EXPIRES_IN=7d
# URL shown in booking confirmation for cancel links (React app)
FRONTEND_URL=http://localhost:3001
# CORS: must match the exact browser origin (scheme + host + port). Comma-separate for several.
# Examples: http://localhost:3001 or http://127.0.0.1:3001
FRONTEND_ORIGIN=http://localhost:3001
# Optional override; default: backend/data/app.db
# SQLITE_PATH=
